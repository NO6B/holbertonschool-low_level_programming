#include <stdio.h>
#include <ctype.h>
#include "main.h"
void print_numbers(void)
/**
* print_numbers - Prints numbers from 0 to 9
* Description: This function prints the numbers from 0 to 9 using a loop
* and the putchar function.
* Return: void
*/
{
int i =0;
while (i < 9)
{
putchar(i);
i++;
}  
}
